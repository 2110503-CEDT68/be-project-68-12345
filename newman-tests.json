          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{user_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"numberOfNights\":3}"},
            "url": "{{base_url}}/bookings/{{user_booking_id}}"
          }
        },
        {
          "name": "3.8 Update Booking (5 Nights - Should Fail)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status code is 400', () => pm.response.to.have.status(400));"
              ]
            }
          }],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{user_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"numberOfNights\":5}"},
            "url": "{{base_url}}/bookings/{{user_booking_id}}"
          }
        },
        {
          "name": "3.9 Delete Booking",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status code is 200', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{user_token}}"}],
            "url": "{{base_url}}/bookings/{{user_booking_id}}"
          }
        }
      ]
    },
    {
      "name": "4. Security Tests",
      "item": [
        {
          "name": "4.1 User Cannot Access Other User Booking",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status code is 403 or 404', () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([403, 404]);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{user2_token}}"}],
            "url": "{{base_url}}/bookings/{{booking_id}}"
          }
        },
        {
          "name": "4.2 Admin Can Access Any Booking",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status code is 200', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": "{{base_url}}/bookings/{{booking_id}}"
          }
        },
        {
          "name": "4.3 Invalid Token Rejected",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status code is 401', () => pm.response.to.have.status(401));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer invalid_token"}],
            "url": "{{base_url}}/bookings"
          }
        }
      ]
    },
    {
      "name": "5. Performance Tests",
      "item": [
        {
          "name": "5.1 Response Time < 3s",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Response time < 3000ms', () => {",
                "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/hotels"
          }
        }
